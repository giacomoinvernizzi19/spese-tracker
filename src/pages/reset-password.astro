---
import '../styles/global.css';
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#3B82F6" />
    <title>Reimposta Password - SpesaTracker</title>
  </head>
  <body class="min-h-screen bg-gradient-to-br from-blue-600 to-blue-800 flex items-center justify-center p-4">
    <div class="w-full max-w-md">
      <!-- Logo -->
      <div class="text-center mb-8">
        <div class="text-6xl mb-2">💰</div>
        <h1 class="text-3xl font-bold text-white">SpesaTracker</h1>
        <p class="text-blue-200 mt-2">Crea una nuova password</p>
      </div>

      <!-- Reset Card -->
      <div class="bg-white rounded-2xl shadow-xl p-8">
        <!-- No Token Message -->
        <div id="noTokenSection" class="hidden">
          <div class="text-center">
            <div class="text-5xl mb-4">❌</div>
            <h2 class="text-2xl font-bold text-gray-900 mb-2">Link non valido</h2>
            <p class="text-gray-600 mb-6">
              Il link di recupero password non e valido o e scaduto.
            </p>
            <a href="/recupera-password" class="inline-block w-full py-3 bg-blue-600 text-white rounded-lg font-semibold hover:bg-blue-700 transition-colors text-center">
              Richiedi nuovo link
            </a>
          </div>
        </div>

        <!-- Reset Form -->
        <div id="resetSection">
          <h2 class="text-2xl font-bold text-gray-900 mb-6 text-center">Nuova password</h2>

          <form id="resetForm" class="space-y-4">
            <input type="hidden" id="token" name="token" />

            <div>
              <label for="password" class="block text-sm font-medium text-gray-700 mb-1">Nuova password</label>
              <input
                type="password"
                id="password"
                name="password"
                required
                minlength="6"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                placeholder="Minimo 6 caratteri"
              />
            </div>

            <div>
              <label for="confirmPassword" class="block text-sm font-medium text-gray-700 mb-1">Conferma password</label>
              <input
                type="password"
                id="confirmPassword"
                name="confirmPassword"
                required
                minlength="6"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                placeholder="Ripeti la password"
              />
            </div>

            <div id="errorMessage" class="hidden text-red-600 text-sm text-center py-2 bg-red-50 rounded-lg"></div>

            <button
              type="submit"
              id="submitBtn"
              class="w-full py-3 bg-blue-600 text-white rounded-lg font-semibold hover:bg-blue-700 transition-colors disabled:bg-blue-300"
            >
              Salva nuova password
            </button>
          </form>
        </div>

        <!-- Success Message -->
        <div id="successSection" class="hidden">
          <div class="text-center">
            <div class="text-5xl mb-4">✅</div>
            <h2 class="text-2xl font-bold text-gray-900 mb-2">Password aggiornata!</h2>
            <p class="text-gray-600 mb-6">
              La tua password e stata reimpostata con successo. Ora puoi accedere con la nuova password.
            </p>
            <a href="/login" class="inline-block w-full py-3 bg-blue-600 text-white rounded-lg font-semibold hover:bg-blue-700 transition-colors text-center">
              Vai al login
            </a>
          </div>
        </div>

        <div id="backLink" class="mt-6 text-center">
          <a href="/login" class="text-blue-600 font-semibold hover:underline">
            &larr; Torna al login
          </a>
        </div>
      </div>
    </div>
  </body>
</html>

<script>
  const resetSection = document.getElementById('resetSection')!;
  const noTokenSection = document.getElementById('noTokenSection')!;
  const successSection = document.getElementById('successSection')!;
  const backLink = document.getElementById('backLink')!;
  const form = document.getElementById('resetForm') as HTMLFormElement;
  const errorMessage = document.getElementById('errorMessage')!;
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
  const tokenInput = document.getElementById('token') as HTMLInputElement;

  // Get token from URL
  const urlParams = new URLSearchParams(window.location.search);
  const token = urlParams.get('token');

  if (!token) {
    resetSection.classList.add('hidden');
    noTokenSection.classList.remove('hidden');
    backLink.classList.add('hidden');
  } else {
    tokenInput.value = token;
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const password = (document.getElementById('password') as HTMLInputElement).value;
    const confirmPassword = (document.getElementById('confirmPassword') as HTMLInputElement).value;

    // Client-side validation
    if (password !== confirmPassword) {
      errorMessage.textContent = 'Le password non corrispondono';
      errorMessage.classList.remove('hidden');
      return;
    }

    if (password.length < 6) {
      errorMessage.textContent = 'La password deve essere di almeno 6 caratteri';
      errorMessage.classList.remove('hidden');
      return;
    }

    errorMessage.classList.add('hidden');
    submitBtn.disabled = true;
    submitBtn.textContent = 'Salvataggio...';

    try {
      const res = await fetch('/api/auth/reset-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token: tokenInput.value, password })
      });

      const data = await res.json();

      if (res.ok) {
        resetSection.classList.add('hidden');
        successSection.classList.remove('hidden');
        backLink.classList.add('hidden');
      } else {
        if (data.error === 'Token non valido o scaduto') {
          resetSection.classList.add('hidden');
          noTokenSection.classList.remove('hidden');
          backLink.classList.add('hidden');
        } else {
          errorMessage.textContent = data.error || 'Errore durante il salvataggio';
          errorMessage.classList.remove('hidden');
          submitBtn.disabled = false;
          submitBtn.textContent = 'Salva nuova password';
        }
      }
    } catch (error) {
      errorMessage.textContent = 'Errore di connessione';
      errorMessage.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Salva nuova password';
    }
  });

  // Check if already logged in
  fetch('/api/auth/me').then(r => r.json()).then(data => {
    if (data.authenticated) {
      window.location.href = '/';
    }
  });
</script>
