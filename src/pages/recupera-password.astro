---
import '../styles/global.css';
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#3B82F6" />
    <title>Recupera Password - SpesaTracker</title>
  </head>
  <body class="min-h-screen bg-gradient-to-br from-blue-600 to-blue-800 flex items-center justify-center p-4">
    <div class="w-full max-w-md">
      <!-- Logo -->
      <div class="text-center mb-8">
        <div class="text-6xl mb-2">💰</div>
        <h1 class="text-3xl font-bold text-white">SpesaTracker</h1>
        <p class="text-blue-200 mt-2">Recupera la tua password</p>
      </div>

      <!-- Recovery Card -->
      <div class="bg-white rounded-2xl shadow-xl p-8">
        <!-- Request Form -->
        <div id="requestSection">
          <h2 class="text-2xl font-bold text-gray-900 mb-2 text-center">Password dimenticata?</h2>
          <p class="text-gray-600 text-center mb-6">Inserisci la tua email e ti invieremo un link per reimpostare la password.</p>

          <form id="recoveryForm" class="space-y-4">
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                placeholder="la-tua@email.it"
              />
            </div>

            <div id="errorMessage" class="hidden text-red-600 text-sm text-center py-2 bg-red-50 rounded-lg"></div>

            <button
              type="submit"
              id="submitBtn"
              class="w-full py-3 bg-blue-600 text-white rounded-lg font-semibold hover:bg-blue-700 transition-colors disabled:bg-blue-300"
            >
              Invia link di recupero
            </button>
          </form>
        </div>

        <!-- Success Message -->
        <div id="successSection" class="hidden">
          <div class="text-center">
            <div class="text-5xl mb-4">📧</div>
            <h2 class="text-2xl font-bold text-gray-900 mb-2">Email inviata!</h2>
            <p class="text-gray-600 mb-6">
              Se l'indirizzo email esiste nel nostro sistema, riceverai un link per reimpostare la password.
            </p>
            <p class="text-gray-500 text-sm mb-6">
              Controlla anche la cartella spam se non trovi l'email.
            </p>
          </div>
        </div>

        <div class="mt-6 text-center">
          <a href="/login" class="text-blue-600 font-semibold hover:underline">
            &larr; Torna al login
          </a>
        </div>
      </div>
    </div>
  </body>
</html>

<script>
  const form = document.getElementById('recoveryForm') as HTMLFormElement;
  const errorMessage = document.getElementById('errorMessage')!;
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
  const requestSection = document.getElementById('requestSection')!;
  const successSection = document.getElementById('successSection')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const email = (document.getElementById('email') as HTMLInputElement).value;

    errorMessage.classList.add('hidden');
    submitBtn.disabled = true;
    submitBtn.textContent = 'Invio in corso...';

    try {
      const res = await fetch('/api/auth/forgot-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email })
      });

      const data = await res.json();

      if (res.ok) {
        // Always show success (don't reveal if email exists)
        requestSection.classList.add('hidden');
        successSection.classList.remove('hidden');
      } else {
        errorMessage.textContent = data.error || 'Errore durante l\'invio';
        errorMessage.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Invia link di recupero';
      }
    } catch (error) {
      errorMessage.textContent = 'Errore di connessione';
      errorMessage.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Invia link di recupero';
    }
  });

  // Check if already logged in
  fetch('/api/auth/me').then(r => r.json()).then(data => {
    if (data.authenticated) {
      window.location.href = '/';
    }
  });
</script>
