---
import AppLayout from '../layouts/AppLayout.astro';
---

<AppLayout title="Nuova Spesa" activeNav="transactions">
  <div class="bg-white rounded-xl shadow-sm overflow-hidden">
    <!-- Header -->
    <div class="flex items-center justify-between p-4 border-b">
      <h2 class="text-xl font-bold">Nuova Spesa</h2>
      <a href="/" class="text-gray-500 hover:text-gray-700 text-2xl leading-none">&times;</a>
    </div>

    <div class="p-4">
      <!-- Amount Display -->
      <div class="text-center mb-6">
        <div id="amountDisplay" class="text-4xl font-bold text-gray-900 mb-2">€ 0.00</div>
        <input
          type="date"
          id="dateInput"
          class="text-sm text-gray-500 bg-transparent border border-gray-200 rounded px-2 py-1 text-center"
        />
      </div>

      <!-- Keypad -->
      <div class="grid grid-cols-4 gap-2 mb-6">
        <button data-key="7" class="keypad-btn h-12 rounded-lg text-xl font-medium bg-gray-100 text-gray-900 hover:bg-gray-200">7</button>
        <button data-key="8" class="keypad-btn h-12 rounded-lg text-xl font-medium bg-gray-100 text-gray-900 hover:bg-gray-200">8</button>
        <button data-key="9" class="keypad-btn h-12 rounded-lg text-xl font-medium bg-gray-100 text-gray-900 hover:bg-gray-200">9</button>
        <button data-key="C" class="keypad-btn h-12 rounded-lg text-xl font-medium bg-red-100 text-red-600 hover:bg-red-200">C</button>

        <button data-key="4" class="keypad-btn h-12 rounded-lg text-xl font-medium bg-gray-100 text-gray-900 hover:bg-gray-200">4</button>
        <button data-key="5" class="keypad-btn h-12 rounded-lg text-xl font-medium bg-gray-100 text-gray-900 hover:bg-gray-200">5</button>
        <button data-key="6" class="keypad-btn h-12 rounded-lg text-xl font-medium bg-gray-100 text-gray-900 hover:bg-gray-200">6</button>
        <button data-key="←" class="keypad-btn h-12 rounded-lg text-xl font-medium bg-gray-200 text-gray-900 hover:bg-gray-300">←</button>

        <button data-key="1" class="keypad-btn h-12 rounded-lg text-xl font-medium bg-gray-100 text-gray-900 hover:bg-gray-200">1</button>
        <button data-key="2" class="keypad-btn h-12 rounded-lg text-xl font-medium bg-gray-100 text-gray-900 hover:bg-gray-200">2</button>
        <button data-key="3" class="keypad-btn h-12 rounded-lg text-xl font-medium bg-gray-100 text-gray-900 hover:bg-gray-200">3</button>
        <button data-key="." class="keypad-btn h-12 rounded-lg text-xl font-medium bg-gray-100 text-gray-900 hover:bg-gray-200">.</button>

        <button data-key="0" class="keypad-btn col-span-2 h-12 rounded-lg text-xl font-medium bg-gray-100 text-gray-900 hover:bg-gray-200">0</button>
        <button data-key="00" class="keypad-btn h-12 rounded-lg text-xl font-medium bg-gray-100 text-gray-900 hover:bg-gray-200">00</button>
        <div></div>
      </div>

      <!-- Categories -->
      <div class="mb-6">
        <label class="block text-sm font-medium text-gray-700 mb-2">Categoria</label>
        <div id="categoriesGrid" class="grid grid-cols-4 gap-2">
          <div class="col-span-4 text-center text-gray-400 py-4">Caricamento...</div>
        </div>
      </div>

      <!-- Description -->
      <div class="mb-6">
        <input
          type="text"
          id="descriptionInput"
          placeholder="Note (opzionale)"
          class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
        />
      </div>

      <!-- Submit Button -->
      <button
        id="submitBtn"
        disabled
        class="w-full py-4 bg-blue-600 text-white rounded-xl font-semibold text-lg hover:bg-blue-700 disabled:bg-gray-300 disabled:cursor-not-allowed transition-colors"
      >
        Salva Spesa
      </button>
    </div>
  </div>
</AppLayout>

<script>
  // State
  let amount = '';
  let selectedCategory: number | null = null;
  let categories: Array<{id: number, name: string, icon: string, color: string}> = [];

  // Elements
  const amountDisplay = document.getElementById('amountDisplay')!;
  const dateInput = document.getElementById('dateInput') as HTMLInputElement;
  const descriptionInput = document.getElementById('descriptionInput') as HTMLInputElement;
  const categoriesGrid = document.getElementById('categoriesGrid')!;
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;

  // Set today's date
  dateInput.value = new Date().toISOString().split('T')[0];

  // Update display
  function updateDisplay() {
    amountDisplay.textContent = amount ? `€ ${amount}` : '€ 0.00';
    submitBtn.disabled = !amount || !selectedCategory;
  }

  // Keypad handlers
  function appendDigit(digit: string) {
    if (digit === '.' && amount.includes('.')) return;
    if (amount.includes('.') && amount.split('.')[1]?.length >= 2) return;
    amount += digit;
    updateDisplay();
  }

  function deleteDigit() {
    amount = amount.slice(0, -1);
    updateDisplay();
  }

  function clearAmount() {
    amount = '';
    updateDisplay();
  }

  // Setup keypad
  document.querySelectorAll('.keypad-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const key = btn.getAttribute('data-key');
      if (key === 'C') clearAmount();
      else if (key === '←') deleteDigit();
      else if (key) appendDigit(key);
    });
  });

  // Load categories
  async function loadCategories() {
    try {
      const res = await fetch('/api/categories');
      categories = await res.json();
      renderCategories();
    } catch (error) {
      console.error('Error loading categories:', error);
      categoriesGrid.innerHTML = '<div class="col-span-4 text-center text-red-500 py-4">Errore caricamento</div>';
    }
  }

  // Render categories
  function renderCategories() {
    categoriesGrid.innerHTML = categories.map(cat => `
      <button
        type="button"
        data-category-id="${cat.id}"
        class="category-btn flex flex-col items-center p-2 rounded-lg border-2 transition-all border-gray-200 hover:border-gray-300"
      >
        <span class="text-2xl">${cat.icon}</span>
        <span class="text-xs text-gray-600 truncate w-full text-center">${cat.name}</span>
      </button>
    `).join('');

    // Add click handlers
    document.querySelectorAll('.category-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = parseInt(btn.getAttribute('data-category-id')!);
        selectCategory(id);
      });
    });
  }

  // Select category
  function selectCategory(id: number) {
    selectedCategory = id;
    document.querySelectorAll('.category-btn').forEach(btn => {
      const btnId = parseInt(btn.getAttribute('data-category-id')!);
      if (btnId === id) {
        btn.classList.remove('border-gray-200');
        btn.classList.add('border-blue-600', 'bg-blue-50');
      } else {
        btn.classList.remove('border-blue-600', 'bg-blue-50');
        btn.classList.add('border-gray-200');
      }
    });
    updateDisplay();
  }

  // Submit
  submitBtn.addEventListener('click', async () => {
    if (!amount || !selectedCategory) return;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Salvataggio...';

    try {
      const res = await fetch('/api/transactions', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          amount: parseFloat(amount),
          category_id: selectedCategory,
          description: descriptionInput.value.trim(),
          date: dateInput.value
        })
      });

      if (res.ok) {
        window.location.href = '/';
      } else {
        alert('Errore nel salvataggio');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Salva Spesa';
      }
    } catch (error) {
      console.error('Error saving:', error);
      alert('Errore nel salvataggio');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Salva Spesa';
    }
  });

  // Keyboard shortcuts
  document.addEventListener('keydown', (e) => {
    if (document.activeElement === descriptionInput) return;

    if (e.key >= '0' && e.key <= '9') appendDigit(e.key);
    if (e.key === '.') appendDigit('.');
    if (e.key === 'Backspace') { e.preventDefault(); deleteDigit(); }
    if (e.key === 'Enter' && amount && selectedCategory) submitBtn.click();
    if (e.key === 'Escape') window.location.href = '/';
  });

  // Init
  loadCategories();
</script>
