---
import AppLayout from '../layouts/AppLayout.astro';
import CategoryPieChart from '../components/charts/CategoryPieChart.svelte';
import MonthlyBarChart from '../components/charts/MonthlyBarChart.svelte';
import TransactionList from '../components/transactions/TransactionList.svelte';

const monthNames = ['Gennaio', 'Febbraio', 'Marzo', 'Aprile', 'Maggio', 'Giugno', 'Luglio', 'Agosto', 'Settembre', 'Ottobre', 'Novembre', 'Dicembre'];
const currentMonth = monthNames[new Date().getMonth()];
const currentYear = new Date().getFullYear();
---

<AppLayout title="Dashboard" activeNav="home">
  <!-- Header Row: Month Selector + Total Card - side by side su desktop -->
  <div class="flex flex-col lg:flex-row gap-6 mb-6">
    <!-- Month Selector -->
    <div class="lg:w-1/3">
      <div class="bg-white rounded-xl p-4 shadow-sm h-full flex items-center justify-between">
        <button id="prevMonth" class="p-2 text-gray-500 hover:text-gray-700 hover:bg-gray-100 rounded-lg transition-colors">
          <span class="text-xl">←</span>
        </button>
        <h2 class="text-lg font-semibold text-gray-800" id="currentMonthLabel">{currentMonth} {currentYear}</h2>
        <button id="nextMonth" class="p-2 text-gray-500 hover:text-gray-700 hover:bg-gray-100 rounded-lg transition-colors">
          <span class="text-xl">→</span>
        </button>
      </div>
    </div>

    <!-- Total Card -->
    <div class="lg:w-2/3">
      <div class="bg-gradient-to-br from-blue-600 to-blue-700 rounded-2xl p-6 text-white shadow-lg h-full">
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
          <div>
            <div class="text-sm opacity-80 mb-1">Speso questo mese</div>
            <div class="text-4xl font-bold" id="monthTotal">
              <span class="animate-pulse">...</span>
            </div>
          </div>
          <div class="flex items-center gap-2 text-sm lg:w-1/2">
            <span class="opacity-80">Budget:</span>
            <div class="flex-1 bg-white/20 rounded-full h-2">
              <div class="bg-white rounded-full h-2 transition-all" style="width: 0%" id="budgetProgress"></div>
            </div>
            <span id="budgetPercent">-</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Charts Row - side by side su desktop -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <CategoryPieChart client:load title="Spese per categoria" />
    <MonthlyBarChart client:load title="Ultimi 6 mesi" />
  </div>

  <!-- Recent Transactions -->
  <div class="bg-white rounded-xl shadow-sm p-4 lg:p-6">
    <div class="flex items-center justify-between mb-4">
      <h3 class="font-semibold text-gray-900">Ultime spese</h3>
      <a href="/transazioni" class="text-blue-600 text-sm hover:underline">Vedi tutte →</a>
    </div>
    <TransactionList client:load apiUrl="/api/transactions?limit=5" desktopTableView={true} />
  </div>
</AppLayout>

<script>
  const monthNames = ['Gennaio', 'Febbraio', 'Marzo', 'Aprile', 'Maggio', 'Giugno', 'Luglio', 'Agosto', 'Settembre', 'Ottobre', 'Novembre', 'Dicembre'];

  let currentMonth = new Date().getMonth();
  let currentYear = new Date().getFullYear();

  async function loadMonthTotal() {
    try {
      const res = await fetch(`/api/stats?month=${currentMonth + 1}&year=${currentYear}`);
      const stats = await res.json();
      const monthTotal = stats.totalMonth || 0;
      document.getElementById('monthTotal')!.textContent = `€ ${monthTotal.toFixed(2)}`;

      // Load and update budget progress
      await loadBudgetProgress(monthTotal);
    } catch (error) {
      console.error('Error loading stats:', error);
      document.getElementById('monthTotal')!.textContent = '€ 0.00';
    }
  }

  async function loadBudgetProgress(spent: number) {
    try {
      const res = await fetch('/api/budgets');
      const budgets = await res.json();

      // Calculate total budget
      const totalBudget = budgets.reduce((sum: number, b: any) => sum + b.amount, 0);

      if (totalBudget > 0) {
        const percentage = Math.min(Math.round((spent / totalBudget) * 100), 100);
        document.getElementById('budgetProgress')!.style.width = `${percentage}%`;
        document.getElementById('budgetPercent')!.textContent = `${percentage}%`;

        // Change color if over budget
        const progressBar = document.getElementById('budgetProgress')!;
        if (spent > totalBudget) {
          progressBar.classList.remove('bg-white');
          progressBar.classList.add('bg-red-400');
          document.getElementById('budgetPercent')!.textContent = `${percentage}% ⚠️`;
        } else {
          progressBar.classList.remove('bg-red-400');
          progressBar.classList.add('bg-white');
        }
      } else {
        document.getElementById('budgetPercent')!.textContent = 'Non impostato';
      }
    } catch (error) {
      console.error('Error loading budgets:', error);
    }
  }

  function updateMonthLabel() {
    document.getElementById('currentMonthLabel')!.textContent = `${monthNames[currentMonth]} ${currentYear}`;
  }

  document.getElementById('prevMonth')?.addEventListener('click', () => {
    currentMonth--;
    if (currentMonth < 0) {
      currentMonth = 11;
      currentYear--;
    }
    updateMonthLabel();
    loadMonthTotal();
  });

  document.getElementById('nextMonth')?.addEventListener('click', () => {
    currentMonth++;
    if (currentMonth > 11) {
      currentMonth = 0;
      currentYear++;
    }
    updateMonthLabel();
    loadMonthTotal();
  });

  // Listen for transaction deletions
  window.addEventListener('transactionDeleted', () => {
    loadMonthTotal();
  });

  // Initial load
  loadMonthTotal();
</script>
