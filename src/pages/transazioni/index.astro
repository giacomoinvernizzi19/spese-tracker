---
import AppLayout from '../../layouts/AppLayout.astro';
import TransactionList from '../../components/transactions/TransactionList.svelte';

const currentMonth = new Date().getMonth() + 1;
const currentYear = new Date().getFullYear();
---

<AppLayout title="Transazioni" activeNav="transactions">
  <!-- Filters Row - responsive -->
  <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4 mb-6">
    <!-- Search (desktop prominent, mobile compact) -->
    <div class="lg:w-1/3">
      <input
        type="search"
        id="searchFilter"
        placeholder="Cerca transazione..."
        class="w-full px-4 py-2 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg text-sm text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
      />
    </div>

    <!-- Filters + Export -->
    <div class="flex flex-wrap items-center gap-2 lg:gap-3">
      <select id="monthFilter" class="px-4 py-2 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg text-sm text-gray-900 dark:text-gray-100">
        <option value="">Tutti i mesi</option>
        <option value="1">Gennaio</option>
        <option value="2">Febbraio</option>
        <option value="3">Marzo</option>
        <option value="4">Aprile</option>
        <option value="5">Maggio</option>
        <option value="6">Giugno</option>
        <option value="7">Luglio</option>
        <option value="8">Agosto</option>
        <option value="9">Settembre</option>
        <option value="10">Ottobre</option>
        <option value="11">Novembre</option>
        <option value="12">Dicembre</option>
      </select>
      <select id="yearFilter" class="px-4 py-2 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg text-sm text-gray-900 dark:text-gray-100">
        <option value="2026">2026</option>
        <option value="2025">2025</option>
        <option value="2024">2024</option>
      </select>
      <button id="exportBtn" class="px-4 py-2 bg-green-600 text-white rounded-lg text-sm hover:bg-green-700 transition-colors">
        📥 Esporta Excel
      </button>
    </div>
  </div>

  <!-- Transaction List with Table View on Desktop -->
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm lg:p-0 pb-20 lg:pb-0">
    <TransactionList
      client:load
      apiUrl={`/api/transactions?month=${currentMonth}&year=${currentYear}&limit=500`}
      desktopTableView={true}
    />
  </div>

  <!-- Total Bar - fixed mobile, inline desktop -->
  <div class="fixed lg:relative bottom-20 lg:bottom-auto left-0 right-0 lg:left-auto lg:right-auto bg-white dark:bg-gray-800 border-t lg:border lg:rounded-xl border-gray-200 dark:border-gray-700 p-4 lg:mt-6 z-40 lg:z-auto">
    <div class="max-w-lg lg:max-w-none mx-auto flex justify-between items-center">
      <span class="text-gray-600 dark:text-gray-400">Totale periodo:</span>
      <span class="text-xl font-bold text-gray-900 dark:text-gray-100" id="periodTotal">
        <span class="animate-pulse">...</span>
      </span>
    </div>
  </div>
</AppLayout>

<script>
  let currentTransactions: any[] = [];
  let filteredTransactions: any[] = [];

  async function loadTransactions() {
    const month = (document.getElementById('monthFilter') as HTMLSelectElement).value;
    const year = (document.getElementById('yearFilter') as HTMLSelectElement).value;

    let url = '/api/transactions?limit=500';
    if (month) url += `&month=${month}`;
    if (year) url += `&year=${year}`;

    try {
      const res = await fetch(url);
      currentTransactions = await res.json();
      applySearchFilter();
    } catch (error) {
      console.error('Error loading transactions:', error);
      document.getElementById('periodTotal')!.textContent = '€ 0.00';
    }
  }

  function applySearchFilter() {
    const searchTerm = (document.getElementById('searchFilter') as HTMLInputElement).value.toLowerCase().trim();

    if (!searchTerm) {
      filteredTransactions = currentTransactions;
    } else {
      filteredTransactions = currentTransactions.filter(t =>
        (t.description?.toLowerCase().includes(searchTerm)) ||
        (t.category_name?.toLowerCase().includes(searchTerm))
      );
    }

    // Update TransactionList via event
    window.dispatchEvent(new CustomEvent('updateTransactionList', { detail: filteredTransactions }));

    // Update total
    const total = filteredTransactions.reduce((sum: number, t: any) => sum + t.amount, 0);
    document.getElementById('periodTotal')!.textContent = `€ ${total.toFixed(2)}`;
  }

  // Handle transaction deletion (update total)
  window.addEventListener('transactionDeleted', () => {
    loadTransactions();
  });

  // Handle export (exports filtered results)
  document.getElementById('exportBtn')?.addEventListener('click', async () => {
    if (filteredTransactions.length === 0) {
      alert('Nessuna spesa da esportare');
      return;
    }

    // Dynamic import xlsx
    const XLSX = await import('xlsx');

    const data = filteredTransactions.map(t => ({
      Data: t.date,
      Categoria: t.category_name || 'N/A',
      Descrizione: t.description || '',
      Importo: t.amount
    }));

    const ws = XLSX.utils.json_to_sheet(data);
    const wb = XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb, ws, 'Spese');
    XLSX.writeFile(wb, `spese_${new Date().toISOString().split('T')[0]}.xlsx`);
  });

  // Filters
  document.getElementById('monthFilter')?.addEventListener('change', loadTransactions);
  document.getElementById('yearFilter')?.addEventListener('change', loadTransactions);

  // Search with debounce
  let searchTimeout: ReturnType<typeof setTimeout>;
  document.getElementById('searchFilter')?.addEventListener('input', () => {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(applySearchFilter, 300);
  });

  // Set current month/year as default
  const now = new Date();
  (document.getElementById('monthFilter') as HTMLSelectElement).value = (now.getMonth() + 1).toString();
  (document.getElementById('yearFilter') as HTMLSelectElement).value = now.getFullYear().toString();

  // Initial load
  loadTransactions();
</script>
