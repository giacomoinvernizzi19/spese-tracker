---
import AppLayout from '../../layouts/AppLayout.astro';
import TransactionList from '../../components/transactions/TransactionList.svelte';

const currentMonth = new Date().getMonth() + 1;
const currentYear = new Date().getFullYear();
---

<AppLayout title="Transazioni" activeNav="transactions">
  <!-- Filters -->
  <div class="flex gap-2 mb-6 overflow-x-auto pb-2">
    <select id="monthFilter" class="px-4 py-2 bg-white border border-gray-300 rounded-lg text-sm">
      <option value="">Tutti i mesi</option>
      <option value="1">Gennaio</option>
      <option value="2">Febbraio</option>
      <option value="3">Marzo</option>
      <option value="4">Aprile</option>
      <option value="5">Maggio</option>
      <option value="6">Giugno</option>
      <option value="7">Luglio</option>
      <option value="8">Agosto</option>
      <option value="9">Settembre</option>
      <option value="10">Ottobre</option>
      <option value="11">Novembre</option>
      <option value="12">Dicembre</option>
    </select>
    <select id="yearFilter" class="px-4 py-2 bg-white border border-gray-300 rounded-lg text-sm">
      <option value="2026">2026</option>
      <option value="2025">2025</option>
      <option value="2024">2024</option>
    </select>
  </div>

  <!-- Export Button -->
  <div class="flex justify-end mb-4">
    <button id="exportBtn" class="px-4 py-2 bg-green-600 text-white rounded-lg text-sm hover:bg-green-700">
      📥 Esporta Excel
    </button>
  </div>

  <!-- Transaction List -->
  <div id="transactionListContainer" class="pb-20">
    <TransactionList
      client:load
      apiUrl={`/api/transactions?month=${currentMonth}&year=${currentYear}&limit=500`}
    />
  </div>

  <!-- Total -->
  <div class="fixed bottom-20 left-0 right-0 bg-white border-t border-gray-200 p-4 z-40">
    <div class="max-w-lg mx-auto flex justify-between items-center">
      <span class="text-gray-600">Totale periodo:</span>
      <span class="text-xl font-bold text-gray-900" id="periodTotal">
        <span class="animate-pulse">...</span>
      </span>
    </div>
  </div>
</AppLayout>

<script>
  let currentTransactions: any[] = [];

  async function loadTransactions() {
    const month = (document.getElementById('monthFilter') as HTMLSelectElement).value;
    const year = (document.getElementById('yearFilter') as HTMLSelectElement).value;

    let url = '/api/transactions?limit=500';
    if (month) url += `&month=${month}`;
    if (year) url += `&year=${year}`;

    try {
      const res = await fetch(url);
      currentTransactions = await res.json();

      // Update TransactionList via event
      window.dispatchEvent(new CustomEvent('updateTransactionList', { detail: currentTransactions }));

      // Update total
      const total = currentTransactions.reduce((sum: number, t: any) => sum + t.amount, 0);
      document.getElementById('periodTotal')!.textContent = `€ ${total.toFixed(2)}`;
    } catch (error) {
      console.error('Error loading transactions:', error);
      document.getElementById('periodTotal')!.textContent = '€ 0.00';
    }
  }

  // Handle transaction deletion (update total)
  window.addEventListener('transactionDeleted', () => {
    loadTransactions();
  });

  // Handle export
  document.getElementById('exportBtn')?.addEventListener('click', async () => {
    if (currentTransactions.length === 0) {
      alert('Nessuna spesa da esportare');
      return;
    }

    // Dynamic import xlsx
    const XLSX = await import('xlsx');

    const data = currentTransactions.map(t => ({
      Data: t.date,
      Categoria: t.category_name || 'N/A',
      Descrizione: t.description || '',
      Importo: t.amount
    }));

    const ws = XLSX.utils.json_to_sheet(data);
    const wb = XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb, ws, 'Spese');
    XLSX.writeFile(wb, `spese_${new Date().toISOString().split('T')[0]}.xlsx`);
  });

  // Filters
  document.getElementById('monthFilter')?.addEventListener('change', loadTransactions);
  document.getElementById('yearFilter')?.addEventListener('change', loadTransactions);

  // Set current month/year as default
  const now = new Date();
  (document.getElementById('monthFilter') as HTMLSelectElement).value = (now.getMonth() + 1).toString();
  (document.getElementById('yearFilter') as HTMLSelectElement).value = now.getFullYear().toString();

  // Initial load
  loadTransactions();
</script>
