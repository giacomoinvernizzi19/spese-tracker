# Cloudflare API Token per questo progetto
# Copia questo file come .env e inserisci il tuo token
#
# Per ottenere il token:
# 1. Vai su https://dash.cloudflare.com/profile/api-tokens
# 2. Crea token con permessi: Workers Scripts (Edit), D1 (Edit)
# 3. Incolla qui sotto

CLOUDFLARE_API_TOKEN=your_token_here
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
